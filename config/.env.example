# ============================================================
#  Mahabharat Shorts Pipeline — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git (it's in .gitignore)
# ============================================================

# ── GEMINI AI (Script Generation) ───────────────────────────
# Free tier — no credit card required
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── YOUTUBE DATA API ─────────────────────────────────────────
# Free — no charges for normal upload volume
# Get from: https://console.cloud.google.com
# Enable: YouTube Data API v3
# Create: OAuth 2.0 credentials (Desktop App)
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secret.json
YOUTUBE_TOKEN_FILE=config/token.json

# ── PROJECT SETTINGS ─────────────────────────────────────────
SERIES_NAME=Mahabharat Cinematic Shorts
CHANNEL_LANGUAGE=hi
# Publish time in UTC (02:30 UTC = 08:00 IST)
PUBLISH_TIME_UTC=02:30
# Output directory (relative to project root)
OUTPUT_DIR=output
# Log directory
LOG_DIR=logs

# ── NOTE: No API keys needed for ─────────────────────────────
# Images  → Pollinations.ai (free, no key)
# Voice   → Microsoft Edge TTS via edge-tts library (free, no key)
# Music   → Pixabay royalty-free tracks (free, no key)

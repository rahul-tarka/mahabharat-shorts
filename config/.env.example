# ============================================================
#  Mahabharat Shorts Pipeline — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git (it's in .gitignore)
# ============================================================

# ── ANTHROPIC (Claude AI) ────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── IDEOGRAM (Scene Images) ──────────────────────────────────
# Get from: https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=your-ideogram-key-here

# ── ELEVENLABS (Hindi Voice) ─────────────────────────────────
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-key-here
# Voice ID — use a deep Hindi male voice
# Find voice IDs at: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=your-voice-id-here

# ── YOUTUBE DATA API ─────────────────────────────────────────
# Get from: https://console.cloud.google.com
# Enable: YouTube Data API v3
# Create: OAuth 2.0 credentials (Desktop App)
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secret.json
YOUTUBE_TOKEN_FILE=config/token.json

# ── SUNO AI (Background Music) ───────────────────────────────
# Optional - or use free royalty-free music from Pixabay
SUNO_API_KEY=your-suno-key-here

# ── PROJECT SETTINGS ─────────────────────────────────────────
SERIES_NAME=Mahabharat Cinematic Shorts
CHANNEL_LANGUAGE=hi
# Publish time in UTC (02:30 UTC = 08:00 IST)
PUBLISH_TIME_UTC=02:30
# Output directory (relative to project root)
OUTPUT_DIR=output
# Log directory
LOG_DIR=logs

# ── OPTIONAL: GOOGLE DRIVE BACKUP ───────────────────────────
# If you want to auto-backup episodes to Google Drive
GDRIVE_FOLDER_ID=your-google-drive-folder-id
